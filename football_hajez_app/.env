# Set to true and fill URL + anon key to use Supabase (Postgres + Auth + RLS) as source of truth.
# Leave false for the original localStorage-only demo.
VITE_USE_SUPABASE=true

# From Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://iiuwduagdaohartfsvvd.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_CVIKYbccx8GQQ60NCxL0gA_HZtlWkgF

# Optional: JSON ingest (POST body { event, properties, ts }). No requests until enabled.
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ENDPOINT=

# Optional: Sentry browser SDK (https://sentry.io). Empty DSN disables Sentry.
VITE_SENTRY_DSN=

# Dev only (npm run dev): skip magic-link OTP and sign in with email+password via Supabase.
# Requires Email provider "password" enabled in Supabase and this user given a password in Dashboard.
# Never set in production builds you ship to users.
# Wrap passwords with $ or # in double quotes — otherwise the value can be corrupted.
# No leading spaces before VITE_ or variables may not load in Vite.
VITE_DEV_HOST_EMAIL=omar.brome@gmail.com
VITE_DEV_HOST_PASSWORD=omar123